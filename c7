   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-2",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Draw 1000 random numbers uniformly distributed between [0, 1]\n",
    "rng = np.random.default_rng(seed=42)\n",
    "samples = rng.uniform(0, 1, 1000)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Histogram the samples into 100 bins and plot\n",
    "fig, ax = plt.subplots(figsize=(8, 5))\n",
    "\n",
    "ax.hist(samples, bins=100, color='steelblue', edgecolor='white', linewidth=0.4)\n",
    "\n",
    "ax.set_xlabel('Value', fontsize=13)\n",
    "ax.set_ylabel('Count', fontsize=13)\n",
    "ax.set_title('Histogram of 1000 Uniform Random Numbers (100 bins)', fontsize=13)\n",
    "ax.grid(True, linestyle='--', alpha=0.5)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('uniform_histogram.pdf')\n",
    "plt.show()\n",
    "print('Figure saved as uniform_histogram.pdf')"
   ]
  }
 ]
