   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-2",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create a numpy array x ranging from 0 to 1 in 100 steps\n",
    "x = np.linspace(0, 1, 100)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Define a function that returns exp(x)\n",
    "def exponential(x):\n",
    "    return np.exp(x)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-4",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Use the function to compute y = exp(x), plot, label axes, and save as PDF\n",
    "y = exponential(x)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 5))\n",
    "ax.plot(x, y, linewidth=2, color='steelblue')\n",
    "ax.set_xlabel('Time [milliseconds]', fontsize=13)\n",
    "ax.set_ylabel('Awesomeness', fontsize=13)\n",
    "ax.set_title('exp(x)', fontsize=15)\n",
    "ax.grid(True, linestyle='--', alpha=0.5)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('exp_plot.pdf')\n",
    "plt.show()\n",
    "print('Figure saved as exp_plot.pdf')"
   ]
  }
 ]
}

