    "---\n",
    "## 3. Lomb-Scargle Periodogram & Sinusoidal Fit\n",
    "\n",
    "Because the data are unevenly sampled over ~16 years, we first use a **Lomb-Scargle periodogram** to identify the dominant oscillation period before fitting.  \n",
    "The oscillatory model we fit is:\n",
    "\n",
    "$$\\text{RV}(t) = K \\sin\\!\\left(\\frac{2\\pi}{P}\\,t + \\varphi\\right) + C$$\n",
    "\n",
    "where $K$ is the semi-amplitude, $P$ the orbital period, $\\varphi$ a phase offset, and $C$ a constant velocity offset."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Lomb-Scargle periodogram ───────────────────────────────────────────────────\n",
    "freqs        = np.linspace(0.001, 0.5, 200_000)   # cycles per day\n",
    "angular_freq = 2 * np.pi * freqs\n",
    "pgram        = lombscargle(t, rv, angular_freq, normalize=True)\n",
    "\n",
    "best_freq   = freqs[np.argmax(pgram)]\n",
    "best_period = 1.0 / best_freq\n",
    "\n",
    "print(f\"Lomb-Scargle dominant period: {best_period:.3f} days\")\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 4))\n",
    "ax.plot(1.0 / freqs, pgram, color='darkorange', linewidth=0.8)\n",
    "ax.axvline(best_period, color='crimson', linestyle='--',\n",
    "           label=f'Best period: {best_period:.3f} d')\n",
    "ax.set_xscale('log')\n",
    "ax.set_xlabel('Period (days)', fontsize=13)\n",
    "ax.set_ylabel('Normalized Power', fontsize=13)\n",
    "ax.set_title('Lomb-Scargle Periodogram — HD 75732', fontsize=14)\n",
    "ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig('periodogram.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Define oscillatory model and fit ──────────────────────────────────────────\n",
    "def rv_model(t, K, P, phi, C):\n",
    "    \"\"\"Single-planet radial velocity model (circular orbit).\n",
    "    \n",
    "    Parameters\n",
    "    ----------\n",
    "    t   : array of times (days)\n",
    "    K   : RV semi-amplitude (m/s)\n",
    "    P   : orbital period (days)\n",
    "    phi : phase offset (radians)\n",
    "    C   : systemic velocity offset (m/s)\n",
    "    \"\"\"\n",
    "    return K * np.sin(2 * np.pi / P * t + phi) + C\n",
    "\n",
    "# Initial parameter guess from periodogram\n",
    "p0 = [120.0, best_period, 0.0, 0.0]\n",
    "\n",
    "# Weighted least-squares fit using measurement uncertainties as weights\n",
    "popt, pcov = curve_fit(\n",
    "    rv_model, t, rv,\n",
    "    p0=p0,\n",
    "    sigma=rv_err,\n",
    "    absolute_sigma=True,\n",
    "    bounds=([0, 1, -np.pi, -200], [300, 1000, np.pi, 200]),\n",
    "    maxfev=100_000\n",
    ")\n",
    "perr = np.sqrt(np.diag(pcov))\n",
    "\n",
    "K_fit, P_fit, phi_fit, C_fit = popt\n",
    "K_err, P_err, phi_err, C_err = perr\n",
    "\n",
    "print(\"Best-fit parameters:\")\n",
    "print(f\"  K   = {K_fit:.3f} ± {K_err:.3f} m/s\")\n",
    "print(f\"  P   = {P_fit:.4f} ± {P_err:.4f} days\")\n",
    "print(f\"  phi = {phi_fit:.4f} ± {phi_err:.4f} rad\")\n",
    "print(f\"  C   = {C_fit:.3f} ± {C_err:.3f} m/s\")"
   ]
